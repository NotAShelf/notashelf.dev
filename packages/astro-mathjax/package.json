{
  "name": "astro-mathjax",
  "type": "module",
  "version": "0.1.0",
  "description": "MathJax math rendering for Astro via remark-math and rehype-mathjax",
  "author": "NotAShelf",
  "license": "MPL-2.0",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.ts"
    }
  },
  "files": [
    "index.ts",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "math",
    "mathjax",
    "remark",
    "rehype"
  ],
  "peerDependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "astro": "^7.0.0"
  },
  "dependencies": {
    "remark-math": "^6.0.0",
    "rehype-mathjax": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
