{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "node scripts/build.js notashelf.dev build",
    "build:web": "node scripts/build.js notashelf.dev build",
    "build:all": "node scripts/build.js --all",
    "dev": "node scripts/dev.js notashelf.dev dev",
    "preview": "pnpm --filter ./apps/notashelf.dev run preview",
    "check": "pnpm --filter ./apps/notashelf.dev run check",
    "fmt": "prettier . --write",
    "lint": "eslint **/*.{ts,js,astro,svelte}",
    "test": "vitest",
    "test:run": "vitest run --config ./vitest.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:web": "vitest run --project notashelf.dev",
    "test:ci": "vitest run --coverage",
    "test:mutants": "stryker run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/eslint": "^9.6.1",
    "@types/postcss-normalize": "^9.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@typescript-eslint/utils": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-svelte": "3.20.0",
    "fs-extra": "^11.3.5",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "prettier": "3.9.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.12",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "astro": "^7.0.7",
    "cssnano": "^8.0.2",
    "glob": "^13.0.6",
    "he": "1.2.0",
    "postcss": "^8.5.15",
    "purgecss": "^8.0.0",
    "svelte": "^5.56.3"
  }
}
