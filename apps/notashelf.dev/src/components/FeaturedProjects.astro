---
import type { ProjectEntry } from "@lib/types";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";

interface Props {
  mode: "featured" | "recent";
  title: string;
}

const { mode, title } = Astro.props;
const shuffleCount = mode === "featured" ? 3 : 5;

// Get all projects
const allProjects = (await getCollection("projects")) as ProjectEntry[];
const featurableProjects = allProjects.filter(
  (project) => project.data.featurable,
);
const activeProjects = featurableProjects.filter(
  (project) => project.data.active,
);
const inactiveProjects = featurableProjects.filter(
  (project) => !project.data.active,
);

// Select projects based on mode
let displayProjects: ProjectEntry[];

if (mode === "featured") {
  // For featured mode: Get ALL projects available for client-side selection
  // The client will pick 3 random ones from this larger pool
  // Use deterministic sorting by id for consistent build output
  const sortedActive = activeProjects.sort((a, b) => a.id.localeCompare(b.id));
  const sortedInactive = inactiveProjects.sort((a, b) =>
    a.id.localeCompare(b.id),
  );

  // Provide all projects to client for random selection
  // Client will pick 3 from this pool and hide the rest
  displayProjects = [...sortedActive, ...sortedInactive];
} else {
  // For recent mode: Get ALL active projects for client-side selection
  // The client will pick 5 random ones from this larger pool
  displayProjects = activeProjects.sort((a, b) => a.id.localeCompare(b.id));
}

// Split projects for the recent mode layout
const topRowProjects = displayProjects.slice(0, 3);
const bottomRowProjects = displayProjects.slice(3);
---

<section
  id="projects-display"
  class="projects-display fade-in"
  data-shuffle-mode={mode}
  data-shuffle-count={shuffleCount}
>
  <h2 class="section-title">{title}</h2>

  {
    mode === "recent" ? (
      <div class="recent-projects-container pre-shuffle-hide-grid">
        <div class="top-row">
          {topRowProjects.map((project) => (
            <ProjectCard
              project={project}
              data-project-id={project.id}
              class="pre-shuffle-hide"
            />
          ))}
        </div>

        <div class="bottom-row">
          {bottomRowProjects.map((project) => (
            <ProjectCard
              project={project}
              data-project-id={project.id}
              class="pre-shuffle-hide"
            />
          ))}
        </div>
      </div>
    ) : (
      <div class="projects-grid pre-shuffle-hide-grid">
        {displayProjects.map((project) => (
          <ProjectCard
            project={project}
            data-project-id={project.id}
            class="pre-shuffle-hide"
          />
        ))}
      </div>
    )
  }

  <div class="see-all">
    <a href="/projects" class="see-all-link">
      View all projects <Icon name="arrow-right" class="arrow-icon" />
    </a>
  </div>
</section>

<script>
  import { projectShuffle } from "../scripts/utils/project-shuffle";

  async function initializeProjectShuffle() {
    try {
      await projectShuffle.setupClientSideShuffling();
      // Remove .pre-shuffle-hide-grid from grid container after shuffle
      document.querySelectorAll(".pre-shuffle-hide-grid").forEach((grid) => {
        grid.classList.remove("pre-shuffle-hide-grid");
      });
    } catch (error) {
      console.warn("Failed to initialize project shuffle:", error);
    }
  }

  initializeProjectShuffle();
</script>

<style lang="scss">
  @use "../styles/global" as *;

  .projects-display {
    margin: 3rem auto;
    width: 100%;
    max-width: 1200px;
    padding: 0 1rem;
  }

  .section-title {
    text-align: center;
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
    position: relative;
    display: inline-block;
    left: 50%;
    transform: translateX(-50%);

    &::after {
      content: "";
      position: absolute;
      bottom: -8px;
      left: 0;
      width: 60%;
      height: 2px;
      background: linear-gradient(
        to right,
        $button-bg,
        $border-medium,
        $button-bg
      );
    }
  }

  .recent-projects-container {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 1.5rem;

    .top-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .bottom-row {
      display: flex;
      justify-content: center;
      gap: 1.25rem;

      .project-card {
        flex-basis: calc(33.333% - 0.85rem);
        max-width: calc(33.333% - 0.85rem);
      }
    }

    @media (max-width: 1024px) {
      .top-row {
        grid-template-columns: repeat(2, 1fr);
      }

      .bottom-row {
        flex-wrap: wrap;

        .project-card {
          flex-basis: calc(50% - 0.625rem);
          max-width: calc(50% - 0.625rem);
        }
      }
    }

    @media (max-width: 640px) {
      .top-row {
        grid-template-columns: 1fr;
      }

      .bottom-row {
        .project-card {
          flex-basis: 100%;
          max-width: 100%;
        }
      }
    }
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 1.5rem;

    @media (max-width: 1024px) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media (max-width: 640px) {
      grid-template-columns: 1fr;
    }
  }

  .pre-shuffle-hide {
    display: none !important;
  }

  .pre-shuffle-hide-grid {
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  .see-all {
    text-align: center;
    margin-top: 1rem;
  }

  .see-all-link {
    @include interactive-card;
    display: inline-flex;
    align-items: center;
    color: $secondary;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    background-color: $card-bg-alt;

    .arrow-icon {
      margin-left: 0.3rem;
      @include smooth-transition(transform);
    }

    &:hover {
      background-color: $card-hover-bg-alt;

      .arrow-icon {
        transform: translateX(4px);
      }
    }
  }

  :global(.arrow-icon) {
    font-size: 1.1em;
    width: 0.9em;
    height: 0.9em;
  }

  :global(.arrow-icon:hover) {
    transform: none;
  }

  @media (max-width: 768px) {
    .projects-grid {
      gap: 1rem;
    }

    .recent-projects-container {
      gap: 1rem;

      .top-row,
      .bottom-row {
        gap: 1rem;
      }
    }
  }
</style>
