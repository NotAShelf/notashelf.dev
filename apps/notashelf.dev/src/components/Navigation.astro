---
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const secondaryNavItems = [
  { title: "Projects", url: "/projects" },
  { title: "Posts", url: "/posts" },
  { title: "About", url: "/about" },
];
---

<div class="nav-outer">
  <div class="nav-wrapper">
    <div class="nav-left">
      <a class={`nav-button ${currentPath === "/" ? "active" : ""}`} href="/">
        Index
      </a>
    </div>
    <div class="nav-right">
      {
        secondaryNavItems.map((item, index) => {
          const isActive = currentPath.startsWith(item.url);
          return (
            <a
              class={`nav-button ${isActive ? "active" : ""}`}
              href={item.url}
              data-key={`nav-${index}`}
            >
              {item.title}
            </a>
          );
        })
      }
    </div>
  </div>
</div>
<hr class="nav-border" />

<style lang="scss">
  @use "../styles/global" as *;
  @use "sass:color";

  .nav-outer {
    position: sticky;
    top: 0;
    z-index: 100;
    background: $primary;
    width: 100%;
    display: flex;
    justify-content: center;
    box-sizing: border-box;
  }

  .nav-wrapper {
    display: flex;
    justify-content: space-between;
    width: 100%;
    max-width: 80ch;
    margin: 0 auto;
    padding: 1.25rem 0;
    box-sizing: border-box;
  }

  .nav-left,
  .nav-right {
    display: flex;
    align-items: center;
  }

  .nav-right {
    justify-content: flex-end;
  }

  .nav-button {
    font-family: Lato, Helvetica, sans-serif;
    font-size: 16px;
    line-height: 1.5;
    font-weight: 800;
    color: color.scale($secondary, $lightness: -10%);
    background: transparent;
    text-decoration: none;
    border: none;
    margin: 0 8px;
    cursor: pointer;
    white-space: nowrap;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;

    &:hover {
      color: $secondary;
    }

    &.active {
      color: $secondary;
      border-bottom-color: rgba(255, 255, 255, 0.25);
    }
  }

  .nav-left .nav-button:first-child {
    margin-left: 0;
  }

  .nav-right .nav-button:last-child {
    margin-right: 0;
  }

  .nav-border {
    background-color: $border-light;
    width: 100%;
    border: none;
    height: 1px;
    margin: 0;
    padding: 0;
  }
</style>
