---
import PostSearch from "@components/PostSearch.svelte";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSortedPosts, isSignificantUpdate } from "@lib/postUtils";
import type { PostEntry } from "@lib/types";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");

const filteredPosts = allPosts.filter(
  (post: PostEntry) => !post.data.draft && !post.data.archived,
);
const sortedPosts = getSortedPosts(filteredPosts);

const postsPerPage = 5;
const totalPages = Math.ceil(sortedPosts.length / postsPerPage);
const currentPage = 1;

const serialize = (post: PostEntry) => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description,
  keywords: post.data.keywords || [],
  date: post.data.date.toISOString(),
  updated: post.data.updated?.toISOString(),
  hasSignificantUpdate: isSignificantUpdate(
    new Date(post.data.date),
    post.data.updated ? new Date(post.data.updated) : undefined,
  ),
});

const pagedPosts = sortedPosts.slice(0, postsPerPage).map(serialize);
const allPostsData = sortedPosts.map(serialize);
const allTags = [
  ...new Set(sortedPosts.flatMap((post: PostEntry) => post.data.keywords || [])),
].sort() as string[];
---

<BaseLayout title="Blog Posts" description="Collection of blog posts">
  <div class="posts-header">
    <h1 class="page-title">Blog Posts</h1>
    <a href="/archive" class="archive-link">
      <Icon name="box-archive" /> View Archive
    </a>
  </div>

  <PostSearch
    pagedPosts={pagedPosts}
    allPosts={allPostsData}
    currentPage={currentPage}
    totalPages={totalPages}
    baseUrl="/posts"
    allTags={allTags}
    client:load
  />
</BaseLayout>

<style lang="scss">
  @use "sass:color";
  @use "../../styles/global" as *;

  .posts-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  .page-title {
    margin-bottom: 0;
  }

  .archive-link {
    @include button-base;
    @include icon-size(0.9rem);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
  }
</style>
